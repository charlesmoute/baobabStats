# NAMESPACE - baobabStats (ecrit a la main)

# ---- API unifiee (prefixe bs_) et addins (bsin_) ----
exportPattern("^bs_")
exportPattern("^bsin_")
export(theme_baobabstats)
export(scale_fill_baobabstats, scale_colour_baobabstats)

# ---- Fonctions moteur exposees aux utilisateurs avances ----
# Qualite intrinseque (CensusAnalytics)
export(assess_data_quality, whipple_index, myers_blended_index, bachi_index,
       check_age_heaping, check_sex_ratio, check_completeness, check_consistency,
       generate_quality_report)
# Qualite a posteriori / PES / DSE (DemoStats)
export(bcstats, quality_check, pes_match, pes_match_auto, pes_reconciliation,
       dse_estimate, coverage_rate, omission_rate, content_error)
# Indicateurs (DemoStats)
export(age_pyramid, sex_ratio, dependency_ratio, median_age,
       fertility_rates, tfr, asfr, cbr, mortality_rates, life_table, imr, cdr,
       migration_rates, education_indicators, literacy_rate, employment_indicators,
       activity_rate, unemployment_rate, disability_prevalence, gender_indicators, gpi)
# Tables / nettoyage / doublons / projections (CensusAnalytics)
export(generate_all_tables, table_population_structure, table_age_pyramid,
       table_nuptiality, standardize_toponyms, impute_missing, impute_mice,
       impute_missforest, clean_census_data, detect_duplicates, cluster_duplicates,
       merge_duplicates, project_cohort_component, project_microsimulation,
       create_projection_scenarios, generate_synthetic_report)

